# 应用配置
DEBUG=false

# 数据库配置
DATABASE_URL=postgresql+asyncpg://crowd_user:crowd_pass_dev@localhost:5432/crowd_counting

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# ZLMediaKit 配置
ZLM_BASE_URL=http://localhost:8080
ZLM_SECRET=your_api_secret_here
ZLM_RTSP_PORT=554
ZLM_HTTP_PORT=80

# CORS 配置
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# 流管理配置
MAX_CONCURRENT_STREAMS=10
AUTO_STOP_DELAY=60
COOLDOWN_DURATION=60

# 文件上传配置
FILE_STORAGE_PATH=/data/uploads
FILE_MAX_SIZE_MB=500
FILE_RETENTION_DAYS=7
FILE_ALLOWED_EXTENSIONS=mp4,avi,mkv,mov,webm,flv

# 推理配置
INFERENCE_FPS=2
CONFIDENCE_THRESHOLD=0.5
HEATMAP_GRID_SIZE=20
HEATMAP_DECAY=0.3
