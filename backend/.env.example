# 应用配置
DEBUG=false

# 数据库配置
DATABASE_URL=postgresql+asyncpg://crowd_user:crowd_pass_dev@localhost:5432/crowd_counting

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# ZLMediaKit 配置
ZLM_BASE_URL=http://localhost:8080
ZLM_EXTERNAL_URL=http://localhost:8080
ZLM_SECRET=your_api_secret_here
ZLM_RTSP_PORT=554
ZLM_RTMP_PORT=1935
ZLM_HTTP_PORT=80

# CORS 配置（使用代码默认值，或用 JSON 格式）
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# 流管理配置
MAX_CONCURRENT_STREAMS=10
AUTO_STOP_DELAY=60
COOLDOWN_DURATION=60

# 文件上传配置
FILE_STORAGE_PATH=/data/uploads
FILE_MAX_SIZE_MB=500
FILE_RETENTION_DAYS=7
# FILE_ALLOWED_EXTENSIONS 使用代码默认值

# 推理配置（方案 E 遗留，已废弃）
INFERENCE_FPS=2
CONFIDENCE_THRESHOLD=0.5
HEATMAP_GRID_SIZE=20
HEATMAP_DECAY=0.5

# ============================================
# 方案 F 渲染配置（服务端渲染热力图）
# ============================================
# 渲染输出帧率 (1-60)
RENDER_FPS=24
# 推理步长，每 N 帧推理一次 (1-10)，24/3=8fps 推理
RENDER_INFER_STRIDE=3
# 热力图叠加透明度 (0-1)
RENDER_OVERLAY_ALPHA=0.4
# 最大并发渲染数
RENDER_MAX_CONCURRENT=2
# FFmpeg 编码预设
RENDER_FFMPEG_PRESET=ultrafast
RENDER_FFMPEG_TUNE=zerolatency

# Redis Streams 配置（方案 F）
RENDER_STATUS_MAXLEN=1000
RENDER_LATEST_RESULT_TTL=60
RENDER_CLEANUP_ON_STOP=true
