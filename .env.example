# ============================================
# 人流计数与密度分析系统 - 环境配置
# ============================================
# 使用说明：
#   1. 复制此文件为 .env
#   2. 修改下方配置项
#   3. 确保 ZLM_SECRET 与 zlm-config/config.ini 中的 [api] secret 一致
# ============================================

# ============================================
# 数据库配置
# ============================================
POSTGRES_PASSWORD=crowd_pass_dev

# ============================================
# ZLMediaKit 配置
# 重要：此密钥必须与 zlm-config/config.ini 的 [api] secret 字段保持一致
# ============================================
ZLM_SECRET=your_api_secret_here_change_in_production

# ============================================
# 部署模式选择
# ============================================
# 
# 【开发模式】后端在宿主机运行，连接 Docker 容器中的基础设施
# 使用命令：docker-compose up -d postgres redis zlmediakit
#
# DATABASE_URL=postgresql+asyncpg://crowd_user:crowd_pass_dev@localhost:5432/crowd_counting
# REDIS_URL=redis://localhost:6379/0
# ZLM_BASE_URL=http://localhost:8080
#
# 【生产模式】所有服务都在 Docker 中运行（推荐）
# 使用命令：docker-compose -f docker-compose.prod.yml up -d
# 注意：生产模式下环境变量由 docker-compose.prod.yml 管理，此处配置仅作参考
#
# DATABASE_URL=postgresql+asyncpg://crowd_user:crowd_pass_dev@postgres:5432/crowd_counting
# REDIS_URL=redis://redis:6379/0
# ZLM_BASE_URL=http://zlmediakit:80

# 默认使用开发模式配置
DATABASE_URL=postgresql+asyncpg://crowd_user:crowd_pass_dev@localhost:5432/crowd_counting
REDIS_URL=redis://localhost:6379/0
ZLM_BASE_URL=http://localhost:8080
ZLM_EXTERNAL_URL=http://localhost:8080

# ZLMediaKit 端口配置
ZLM_RTSP_PORT=554
ZLM_RTMP_PORT=1935
ZLM_HTTP_PORT=80

# ============================================
# 文件存储配置
# ============================================
FILE_STORAGE_PATH=/data/uploads
FILE_MAX_SIZE_MB=500
FILE_RETENTION_DAYS=7
FILE_ALLOWED_EXTENSIONS=mp4,avi,mkv,mov,webm,flv

# ============================================
# YOLO 推理配置
# ============================================
# 推理帧率（每秒处理帧数，降低可减少 CPU 占用）
INFERENCE_FPS=2
# 检测置信度阈值（0-1，越高越严格）
CONFIDENCE_THRESHOLD=0.5
# 热力图网格大小
HEATMAP_GRID_SIZE=20
# 热力图衰减系数
HEATMAP_DECAY=0.3

# ============================================
# 渲染配置（方案F：服务端渲染热力图）
# 验收口径：延迟 1-5s / 渲染 24fps / 推理 8fps（24/3）
# ============================================
RENDER_FPS=24
RENDER_INFER_STRIDE=3
RENDER_OVERLAY_ALPHA=0.4
RENDER_MAX_CONCURRENT=2
RENDER_FFMPEG_PRESET=ultrafast
RENDER_FFMPEG_TUNE=zerolatency

# ============================================
# 系统配置
# ============================================
# 最大并发流数量
MAX_CONCURRENT_STREAMS=10
# 无观看者自动停止延迟（秒）
AUTO_STOP_DELAY=60
# 冷却时间（秒）
COOLDOWN_DURATION=60

# ============================================
# WebSocket 配置
# ============================================
WS_HEARTBEAT_INTERVAL=30
WS_HEARTBEAT_TIMEOUT=10
WS_SLOW_CLIENT_THRESHOLD=5

# ============================================
# Redis Streams 配置
# ============================================
STREAM_RESULT_MAXLEN=500
STREAM_STATUS_MAXLEN=1000
STREAM_READ_BLOCK_MS=1000
STREAM_READ_COUNT=100
STREAM_RECOVER_COUNT=50

# ============================================
# 快照配置
# ============================================
SNAP_TIMEOUT_SEC=2.0
SNAP_MAX_FAILURES=5
SNAP_BACKOFF_BASE=1.0
SNAP_BACKOFF_MAX=30.0

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json
