# 环境配置示例
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_ENV=development
DEBUG=true

# SQLite 数据库配置
DATABASE_URL=sqlite:///data/crowdflow.db

# Redis 配置（可选，用于缓存）
REDIS_URL=redis://localhost:6379/0

# YOLO 模型配置
MODEL_PATH=models/yolov8n.pt
CONFIDENCE_THRESHOLD=0.5

# 上传文件配置
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=104857600  # 100MB

# API 配置
API_HOST=0.0.0.0
API_PORT=8000

# 前端配置
VITE_API_URL=http://localhost:8000
