# CrowdFlow 配置文件
# 复制此文件为 .env 并根据需要修改

# ===================
# 开发环境配置
# ===================
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ===================
# 本地 / Docker 端口映射
# ===================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ===================
# 路径配置（按需覆盖）
# ===================
# DATABASE_URL=
# YOLO_MODEL_PATH=/absolute/path/to/model.pt

# ===================
# YOLO 配置
# ===================
YOLO_CONF_THRESHOLD=0.5
YOLO_DEVICE=cpu                   # cpu / cuda / mps
YOLO_CLASSES=0                    # 检测类别，逗号分隔。0=Person(身体), 1=Head(头部)

# ===================
# DM-Count 密度图配置
# ===================
DMCOUNT_MODEL_NAME=DM-Count
DMCOUNT_MODEL_WEIGHTS=QNRF        # SHA / SHB / QNRF (QNRF 场景多样性最好)
DMCOUNT_INTERVAL_SEC=1.0          # DM-Count 运行间隔（秒），同时控制画面推送频率

# ===================
# 告警配置
# ===================
ALERT_COOLDOWN_SECONDS=30         # 同一区域告警冷却时间（秒）

# ===================
# WebSocket 配置
# ===================
WS_HEARTBEAT_INTERVAL=30          # 心跳间隔（秒）
# WS_PUSH_FPS=0                   # 推送帧率上限，0=跟随 DM-Count 间隔

# ===================
# 推理流水线说明
# ===================
# YOLO: 每帧静默运行（追踪 + 区域计数 + 计数线），不参与画面渲染
# DM-Count: 按 DMCOUNT_INTERVAL_SEC 间隔运行，负责密度估计 + 热力图渲染 + 画面推送
#
# 调优建议:
#   GPU 充足: DMCOUNT_INTERVAL_SEC=0.5, YOLO_DEVICE=cuda
#   CPU 环境: DMCOUNT_INTERVAL_SEC=2.0, YOLO_DEVICE=cpu
#   低延迟流: DMCOUNT_INTERVAL_SEC=1.0

# 前端在构建静态资源时才需要此变量，日常本地开发通常可留空
# VITE_API_URL=http://localhost:8000
