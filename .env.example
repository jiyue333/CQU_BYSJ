# CrowdFlow 配置文件
# 复制此文件为 .env 并根据需要修改

# ===================
# 开发环境配置
# ===================
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ===================
# 本地 / Docker 端口映射
# ===================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ===================
# 路径配置（按需覆盖）
# ===================
# DATABASE_URL=
# YOLO_MODEL_PATH=/absolute/path/to/model.pt

# ===================
# YOLO 配置
# ===================
YOLO_CONF_THRESHOLD=0.5
YOLO_DEVICE=cpu

# ===================
# 告警与密度配置
# ===================
ALERT_COOLDOWN_SECONDS=30
DENSITY_FACTOR=10000
DENSITY_MAX=100

# 前端在构建静态资源时才需要此变量，日常本地开发通常可留空
# VITE_API_URL=http://localhost:8000
