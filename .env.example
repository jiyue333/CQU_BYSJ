# CrowdFlow 配置文件
# 复制此文件为 .env 并根据需要修改

# ===================
# 开发环境配置
# ===================
# Python 环境类型: conda / venv
PYTHON_ENV=conda
# conda 环境名称（仅 PYTHON_ENV=conda 时有效）
CONDA_ENV_NAME=crowdflow

# ===================
# 应用配置
# ===================
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ===================
# Docker 端口映射
# ===================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ===================
# YOLO 模型配置
# ===================
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONF_THRESHOLD=0.5
YOLO_DEVICE=cpu

# ===================
# 告警阈值配置
# ===================
# 总人数达到此值触发警告
ALERT_TOTAL_WARNING=50
# 总人数达到此值触发严重告警
ALERT_TOTAL_CRITICAL=100
# 告警冷却时间（秒）
ALERT_COOLDOWN_SECONDS=30

# ===================
# 前端配置
# ===================
VITE_API_URL=http://localhost:8000
